class Solution:
    def findRelativeRanks(self, score: List[int]) -> List[str]:
        s1=sorted(score,reverse=True)
        hashmap={}
        hashmap[s1[0]]="Gold Medal"
        if len(score)>1:
            hashmap[s1[1]]="Silver Medal"
        if len(score)>2:
            hashmap[s1[2]]="Bronze Medal"
        if len(score)>3:
            for i in range(3,len(s1)):
                hashmap[s1[i]]=str(i+1)
      

        res=[]
        for i in score:
            if i in hashmap:
                res.append(hashmap[i])
        return res

        
