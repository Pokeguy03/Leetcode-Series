class Solution:
    def countDistinctIntegers(self, nums: List[int]) -> int:
        temp=nums[:]
    
        for i in nums:
            rev=0
            x=i
            while x!=0:
                rem=x%10
                rev=rev*10+rem
                x//=10
            temp.append(rev)
        return len(set(temp))
