class Solution:
    def reversePrefix(self, word: str, ch: str) -> str:
        if ch not in word:
            return word
        str=""
        for i in range(len(word)):
            if word[i]==ch:
                str=str+word[:i+1]
                break
        str=str[::-1]
        print(str)
        str=str+word[i+1:]
        return  str


