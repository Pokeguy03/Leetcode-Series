# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def deleteMiddle(self, head: Optional[ListNode]) -> Optional[ListNode]:
        dummy=ListNode(0)
        dummy.next=head
        curr=dummy
        slow=curr.next
        fast=curr.next
        while fast and fast.next:
            curr=curr.next
            slow=slow.next
            fast=fast.next.next

        curr.next=slow.next
        return dummy.next
        
