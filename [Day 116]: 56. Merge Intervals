#Method 1
class Solution:
    def merge(self, intervals: List[List[int]]) -> List[List[int]]:
        intervals.sort()
        ans=[intervals[0]]
        for inte in intervals[1:]:
            start=inte[0]
            end=inte[1]
            if (start <= ans[-1][1]):
                ans[-1][1]=max(end,ans[-1][1])
            else:
                ans.append([start,end])
        return ans

#Method 2
class Solution:
    def merge(self, intervals: List[List[int]]) -> List[List[int]]:
        intervals.sort()
        
        i=0
        while i<=len(intervals)-2:
            if intervals[i][1]>=intervals[i+1][0] and intervals[i][1]>=intervals[i+1][1]:
                intervals.pop(i+1)
            elif intervals[i][1]>=intervals[i+1][0]:
                intervals[i][1]=intervals[i+1][1]
                intervals.pop(i+1)
            elif intervals[i][0]==intervals[i+1][0] and intervals[i][1]==intervals[i+1][1]:
                intervals.pop(i+1)
                
            else:
                i+=1           

        return intervals

        
