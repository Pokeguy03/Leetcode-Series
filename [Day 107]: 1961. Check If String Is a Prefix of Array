class Solution:
    def isPrefixString(self, s: str, words: List[str]) -> bool:
        # prefix="".join(words)
        # if s==prefix[:len(s)]:
        #     return True
        # else:
        #     return False
        prefix=""
        for i in words:
            prefix+=i
            if s==prefix:
                return True
            if len(prefix)>len(s):
                return False
        return False
