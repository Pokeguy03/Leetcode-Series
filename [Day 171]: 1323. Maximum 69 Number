class Solution:
    def maximum69Number (self, num: int) -> int:
        nums=list(str(num))
        maxi=num
        for i in range(len(nums)):
            if nums[i]=='9':
                nums[i]='6'
                j=''.join(nums)
                maxi=max(maxi,int(j))
                nums[i]='9'
            else:
                
                nums[i]='9'
                j=''.join(nums)
                maxi=max(maxi,int(j))
                nums[i]='6'
        return maxi
        
