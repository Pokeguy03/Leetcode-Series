class Solution:
    def findMaxK(self, nums: List[int]) -> int:
        li=[]
        l=0
        r=len(nums)-1
        nums.sort()
        while l<r:
            if nums[l]==-1*nums[r]: 
                li.append(abs(nums[l]))
                l+=1
                r-=1
            elif nums[l]<-nums[r]:
                l+=1
            else:
                r-=1
        if not li:
            return -1
        else:
            maxi=float("-inf")
            for i in li:
                if i>maxi:
                    maxi=i
            return (maxi)
