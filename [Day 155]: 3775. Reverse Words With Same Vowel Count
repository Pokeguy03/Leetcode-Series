class Solution:
    def reverseWords(self, s: str) -> str:
        vowels=["a","e","i","o","u"]
        s=s.split( )
        
        li=[]
    
        for i in s:
            count=0
            for j in i:
                if j in vowels:
                    count+=1
            li.append(count)
            count=0
        print(li)
        for i in range(1,len(li)):
            if li[i]==li[0]:
                s[i]=s[i][::-1]
        return " ".join(s)


            
        
