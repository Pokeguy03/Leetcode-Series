class Solution:
    def trimTrailingVowels(self, s: str) -> str:
        
        rev_w=s[::-1]
        print(rev_w)
        vow=["a","e","i","o","u"]
        res=""
        for i in rev_w:
            if i not in vow:
                res += i   
            else:
                if res == "":  
                    continue
                else:
                    res += i

        return res[::-1]

