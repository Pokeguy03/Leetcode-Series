class Solution:
    def gcdOfOddEvenSums(self, n: int) -> int:
        def gcd(a,b):
            while b!=0:
                a,b=b,a%b
            return a
        even=0
        odd=0
        for i in range(1,n+n+1):
            if i%2==0:
                even+=i
            else:
                odd+=i
        return(gcd(odd,even))
       
