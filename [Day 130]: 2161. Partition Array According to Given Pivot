class Solution:
    def pivotArray(self, nums: List[int], pivot: int) -> List[int]:
        res1=[]
        res2=[]
        res3=[]
        for i in nums:
            if i>pivot:
                res1.append(i)
            elif i==pivot:
                res2.append(i)
            else:
                res3.append(i)
        return (res3+res2+res1)

        
