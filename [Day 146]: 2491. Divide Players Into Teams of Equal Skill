class Solution:
    def dividePlayers(self, skill: List[int]) -> int:
        i=0
        ans=0
        j=len(skill)-1
        n=len(skill)
        skill.sort()
        target=skill[0]+skill[n-1]
        while i<j:
            if skill[i]+skill[j]!=target:
                return -1
            ans += skill[i] * skill[j]
            i+=1
            j-=1
        return ans
       
        
