class Solution:
    def numIdenticalPairs(self, nums: List[int]) -> int:
        count=0
        for i in range(len(nums)):
            for j in range(i,len(nums)):
                if nums[i]==nums[j] and i<j:
                    count+=1
        return count


#n2c Combination
class Solution:
    def numIdenticalPairs(self, nums: List[int]) -> int:
        dic = Counter(nums)
        ct = 0
        for a in dic.values():
            ct += a * (a - 1) // 2
        return ct

