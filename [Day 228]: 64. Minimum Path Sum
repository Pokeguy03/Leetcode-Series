#Top Down (Done by me)
class Solution:
    def minPathSum(self, grid: List[List[int]]) -> int:
        m=len(grid)
        n=len(grid[0])
        memo=[[-1]* n for _ in range(m)]
        def path(m,n):
            if m==0 and n==0:
                return grid[m][n]
            if m<0 or n<0:
                return float("inf")
            if memo[m][n]!=-1:
                return memo[m][n]
            up=grid[m][n]+path(m-1,n)
            left=grid[m][n]+path(m,n-1)
            memo[m][n]=min(up,left)
            return memo[m][n]
        return path(m-1,n-1)        

