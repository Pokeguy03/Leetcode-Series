class Solution:
    def convert(self, s: str, numRows: int) -> str:
        
        rows= [""] * numRows 
        current_row=0
        down=False
        if numRows==1 or numRows>=len(s):
            return s
        for i in s:
            rows[current_row] += i
            if current_row == 0 or current_row == numRows-1:
                down = not down
            if down:
                current_row+=1
            else:
                current_row-=1
        return "".join(rows)
            
        
