class Solution:
    def longestMountain(self, arr: List[int]) -> int:
        maxi=0
        i=1
        
        while i<len(arr)-1:
            if arr[i-1]<arr[i]>arr[i+1]:
                left=i
                right=i
                while left>0 and arr[left-1]<arr[left]:
                    left-=1
                while right<len(arr)-1 and arr[right+1]<arr[right]:
                    right+=1
                maxi=max(maxi,right-left+1)
                i=right

            else:
                i+=1
        return maxi
        
