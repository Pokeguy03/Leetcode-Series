class Solution:
    def minAddToMakeValid(self, s: str) -> int:
        count=0
        s=list(s)
        stack=[]
        for i in s:
            if not stack:
                if i==")":
                    count+=1
                    continue

            if i=="(":
                stack.append(i)
            elif i==")":
                stack.pop()
        return count+len(stack)
            
        
