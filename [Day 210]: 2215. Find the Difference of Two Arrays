class Solution:
    def findDifference(self, nums1: List[int], nums2: List[int]) -> List[List[int]]:
        nums1=set(nums1)
        nums2=set(nums2)
        fi=[]
        res1=[]
        for i in nums1:
            if i not in nums2:
                res1.append(i)
        fi.append(res1)
        res2=[]
        for j in nums2:
            if j not in nums1:
                res2.append(j)
        fi.append(res2)
        return fi

