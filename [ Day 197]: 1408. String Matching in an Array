class Solution:
    def stringMatching(self, words: List[str]) -> List[str]:
        li=[]
        for i in range(len(words)):
            for j in range(len(words)):
                if len(words[i])>=len(words[j]) and i!=j:
                    if words[j] in words[i]:
                        li.append(words[j])
        return list(set(li))
