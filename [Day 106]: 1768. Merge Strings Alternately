class Solution:
    def mergeAlternately(self, word1: str, word2: str) -> str:
        l=0
        r=0
        li=[]
        while l<len(word1) and r<len(word2):
            li.append(word1[l])
            l+=1
            li.append(word2[r])
            r+=1
        li.extend(word1[l:])
        li.extend(word2[r:])
        return "".join((li))

        
