class Solution:
    def frequencySort(self, nums: List[int]) -> List[int]:
        freq=Counter(nums)
#Method 1
        count=[]
        
        while nums:
            mini=nums[0]
            for i in nums:
                if freq[i]<freq[mini]:
                    mini=i
                elif freq[i]==freq[mini] and i>mini:
                    mini=i
            for i in range(freq[mini]):
                count.append(mini)
                nums.remove(mini)
        return count
#method 2

        nums.sort(key=lambda x: (freq[x],-x))
        return nums
            



        
