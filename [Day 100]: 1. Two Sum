#method 1
class Solution:
	def twoSum(self, arr, target):
		for i in range(len(arr)):
		    for j in range(i+1,len(arr)):
		        if arr[i]+arr[j]==target:
		            return True
#Two Pointer
        arr.sort()
        left, right = 0, len(arr) - 1
    
        while left < right:
            sum = arr[left] + arr[right]
            if sum == target:
                return True
            elif sum < target:
                left += 1
            else:
                right -= 1
        return False
            
