class Solution:
    def countBalls(self, lowLimit: int, highLimit: int) -> int:
        li={}
        for i in range(lowLimit,highLimit+1):
            summ=0
            n=i
            while n>0:
                digit=n%10
                summ=summ+digit
                n//=10

            if summ not in li:
                li[summ]=1
            else:
                li[summ]+=1
        return max(li.values())

        
