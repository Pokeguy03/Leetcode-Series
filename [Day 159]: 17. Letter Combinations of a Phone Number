from typing import List

class Solution:
    def letterCombinations(self, digits: str) -> List[str]:
        
        if not digits:
            return []

        res = []

        dic = {
            "2": ["a","b","c"],
            "3": ["d","e","f"],
            "4": ["g","h","i"],
            "5": ["j","k","l"],   
            "6": ["m","n","o"],
            "7": ["p","q","r","s"],
            "8": ["t","u","v"],
            "9": ["w","x","y","z"]
        }

        def backtrack(index, path):
            if index == len(digits):
                res.append(path)
                return

            for ch in dic[digits[index]]:
                backtrack(index + 1, path + ch)

        backtrack(0, "")
        return res
