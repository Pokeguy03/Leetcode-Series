# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        #Base Case
        if not head or not head.next or k==0:
            return head

        #to calculate a length
        tail=head
        length=1
        while tail.next:
            tail=tail.next
            length+=1
        print(length)

        #to make it circular
        tail.next=head

        #to find the new tail and new_head
        k=k%length
        steps=length-k
        new_tail=head
        for _ in range(steps-1):
            new_tail=new_tail.next
        new_head=new_tail.next
        new_tail.next=None

        return new_head
