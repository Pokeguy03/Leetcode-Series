class Solution:
    def toGoatLatin(self, sentence: str) -> str:
        sentence=sentence.split()
        li=[]
        fi=[]
        for i in sentence:
            if i[0].lower() in "aeiou":
                li.append(i + "ma")
            else:
                li.append(i[1:]+ i[0]+"ma")
        fi.append(li[0]+'a')
        for i in range(1,len(sentence)):
            fi.append(li[i]+('a'*(i+1)))
        return " ".join(fi)

            

        
