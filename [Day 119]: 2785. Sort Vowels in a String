class Solution:
    def sortVowels(self, s: str) -> str:
        vowels="aeiouAEIOU"
        li=[]
        for i in s:
            if i in vowels:
                li.append(i)
        sort=sorted(li)
        s=list(s)
        index=0
        for i in range(len(s)):
            if s[i] in vowels:
                s[i]=sort[index]
                index+=1
        return "".join(s)

                
        return s
                
                
       

