class Solution:
    def sumAndMultiply(self, n: int) -> int:
        n=str(n)
        res=[]
        for i in n:
            if i!="0":
                res.append(int(i))
       
        summ=sum(res)
        if res:
            x=int("".join(map(str,res)))
        else:
            return 0
      
        return (x*summ)
        

        
