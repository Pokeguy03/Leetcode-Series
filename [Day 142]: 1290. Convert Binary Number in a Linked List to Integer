# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def getDecimalValue(self, head: Optional[ListNode]) -> int:
        li=[]
        curr=head
        while curr:
            li.append(curr.val)
            curr=curr.next
        li_n=[]
        for i in li:
            li_n.append(str(i))
        print(li_n)
        bi="".join(li_n)
        fi_bi=(int(bi,2))
        return fi_bi
            

       
