class Solution:
    def areAlmostEqual(self, s1: str, s2: str) -> bool:
        
        if s1==s2:
            return True
        li=[]
        for i in range(len(s1)):
            if s1[i]!=s2[i]:
                li.append(i)

        if len(li)!=2:
            return False
        
        s1=list(s1)
        s2=list(s2)
        return (s1[li[0]], s1[li[1]]) == (s2[li[1]], s2[li[0]])

