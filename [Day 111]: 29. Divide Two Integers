class Solution:
    def divide(self, dividend: int, divisor: int) -> int:
        if dividend == -2**31 and divisor == -1:
            return 2**31 - 1
        neg=(dividend<0)!=(divisor<0)
        divide=abs(dividend)
        divise=abs(divisor)
        res=divide//divise

        if neg:
            return -res
        else:
            return res
        
